{
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [
          "nixfmt"
        ]
      },
      "nixpkgs": {
        "expr": "import <nixpkgs> { }"
      },
      "options": {
        "home-manager": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").darwinConfigurations.fh-workmac.options.home-manager.users.type.getSubOptions []"
        },
        "nix-darwin": {
          "expr": "(builtins.getFlake \"${workspaceFolder}\").darwinConfigurations.fh-workmac.options"
        }
      }
    }
  },
  "files.exclude": {
    "result/": true,
  }
}
